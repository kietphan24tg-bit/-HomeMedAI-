{
    "name": "homemedai",
    "main": "expo-router/entry",
    "version": "1.0.0",
    "scripts": {
        "start": "expo start --max-workers 1",
        "reset-project": "node ./scripts/reset-project.js",
        "android": "expo run:android",
        "android:device": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-android-device.ps1",
        "android:assemble:arm64": "scripts\\android-with-lowmem-native.cmd app:assembleDebug -PreactNativeArchitectures=arm64-v8a -PreactNativeDevServerPort=8081 -x lint -x test --configure-on-demand --build-cache",
        "android:assemble:x64": "scripts\\android-with-lowmem-native.cmd app:assembleDebug -PreactNativeArchitectures=x86_64 -PreactNativeDevServerPort=8081 -x lint -x test --configure-on-demand --build-cache",
        "android:gradle:stop": "cd android && gradlew.bat --stop",
        "android:run": "npm run android:run:x64",
        "android:run:arm64": "npm run android:assemble:arm64 && npx expo run:android --binary android/app/build/outputs/apk/debug/app-debug.apk",
        "android:run:x64": "npm run android:assemble:x64 && npx expo run:android --binary android/app/build/outputs/apk/debug/app-debug.apk",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
        "build:auth-session-tests": "tsc -p tsconfig.auth-tests.json",
        "check:auth-session": "node ./scripts/check-auth-session.mjs",
        "test:auth-session-runtime": "npm run build:auth-session-tests && node ./tests/auth/run-runtime-tests.cjs",
        "typecheck": "tsc --noEmit",
        "check-all": "npm run typecheck && npm run lint && npm run format:check && npm run check:auth-session && npm run test:auth-session-runtime",
        "prepare": "husky",
        "postinstall": "node ./patch-reanimated.js"
    },
    "dependencies": {
        "@expo-google-fonts/inter": "^0.4.2",
        "@expo/vector-icons": "^15.0.3",
        "@react-native-async-storage/async-storage": "^3.0.2",
        "@react-native-community/datetimepicker": "8.4.4",
        "@react-native-google-signin/google-signin": "^16.1.2",
        "@react-navigation/bottom-tabs": "^7.4.0",
        "@react-navigation/elements": "^2.6.3",
        "@react-navigation/native": "^7.1.8",
        "@react-navigation/native-stack": "^7.3.16",
        "@tanstack/react-query": "^5.95.2",
        "axios": "^1.13.6",
        "expo": "~54.0.33",
        "expo-constants": "~18.0.13",
        "expo-dev-client": "~6.0.20",
        "expo-document-picker": "~14.0.8",
        "expo-font": "~14.0.11",
        "expo-haptics": "~15.0.8",
        "expo-image": "~3.0.11",
        "expo-image-picker": "~17.0.10",
        "expo-linear-gradient": "~15.0.8",
        "expo-linking": "~8.0.11",
        "expo-router": "~6.0.23",
        "expo-secure-store": "~15.0.8",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.9",
        "expo-symbols": "~1.0.8",
        "expo-system-ui": "~6.0.9",
        "expo-web-browser": "~15.0.10",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "react-native-device-info": "^15.0.2",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-reanimated": "~4.1.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-svg": "15.12.1",
        "react-native-web": "~0.21.0",
        "react-native-worklets": "^0.8.1",
        "sonner-native": "^0.23.1",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@types/react": "~19.1.0",
        "eslint": "^9.25.0",
        "eslint-config-expo": "~10.0.0",
        "eslint-config-prettier": "^10.1.0",
        "eslint-plugin-import": "^2.31.0",
        "husky": "^9.1.0",
        "lint-staged": "^15.4.0",
        "prettier": "^3.5.0",
        "prettier-plugin-organize-imports": "^4.1.0",
        "typescript": "~5.9.2"
    },
    "private": true
}
