{
    "cli": {
        "version": ">= 18.6.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development",
            "android": {
                "buildType": "apk"
            }
        },
        "development-local": {
            "extends": "development"
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "autoIncrement": true,
            "channel": "production"
        }
    },
    "submit": {
        "production": {}
    }
}
